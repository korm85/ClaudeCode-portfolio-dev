{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // \"\"' | { read -r cmd; echo \"$cmd\" | grep -q 'vercel --prod' && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":\"WRAP_TRIGGER: Deploy detected — run /done to update STATUS.md and write the next session starter.\"}}' || true; }",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/global-session-start.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/global-session-start.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "${HOME}/.claude/hooks/global-session-start.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "superpowers@obra": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "product-tracking-skills@claude-plugins-official": true,
    "playwright@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true,
  "agentPushNotifEnabled": true,
  "env": {
    "GITHUB_TOKEN": "GITHUB_TOKEN_PLACEHOLDER",
    "GH_TOKEN": "GITHUB_TOKEN_PLACEHOLDER"
  },
  "remoteControlAtStartup": true
}
